            android:background="@drawable/stylo_borde_buttons"
            android:text="√"
            android:textSize="24sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/buttonSeno"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="sin"
            android:textSize="24sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/buttonCoseno"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="cos"
            android:textSize="24sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/button0"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="0"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="4" />

        <Button
            android:id="@+id/buttonsuma2"
            style="@style/FontStyle"
            android:layout_width="187dp"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="="
            android:textSize="24sp"
            app:layout_column="2"
            app:layout_columnSpan="2"
            app:layout_columnWeight="0"
            app:layout_row="4" />

        <Button
            android:id="@+id/buttonpunto"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="."
            android:textSize="24sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="4" />

    </androidx.gridlayout.widget.GridLayout>
</LinearLayout>