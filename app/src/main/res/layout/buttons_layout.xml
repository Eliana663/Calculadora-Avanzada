<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:onClick="resetAC"
    android:orientation="vertical">

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20px"
        app:columnCount="4"
        app:rowCount="6">

        <Button
            android:id="@+id/igual"
            style="@style/FontStyle"
            android:layout_width="185dp"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="resetAC"
            android:text="AC"
            android:textSize="30sp"
            app:layout_column="0"
            app:layout_columnSpan="2"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/igual2"
            style="@style/FontStyle"
            android:layout_width="185dp"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="igual"
            android:text="="
            android:textSize="30sp"
            app:layout_column="2"
            app:layout_columnSpan="2"
            app:layout_columnWeight="0"
            app:layout_row="4" />

        <Button
            android:id="@+id/porcentaje"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="porcentaje"
            android:text="%"
            android:textSize="30sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/dividir"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="pulsarOperacion"
            android:tag="division"
            android:text="/"
            android:textSize="30sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/button7"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="7"
            android:textSize="30sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/multiplicar"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="pulsarOperacion"
            android:tag="multiplicacion"
            android:text="*"
            android:textSize="30sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/button8"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="8"
            android:textSize="30sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/button9"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="9"
            android:textSize="30sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/button4"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="4"
            android:textSize="30sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/resta"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="pulsarOperacion"
            android:tag="resta"
            android:text="-"
            android:textSize="30sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/button5"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="5"
            android:textSize="30sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/button6"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="6"
            android:textSize="30sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/button1"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="1"
            android:textSize="30sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/suma"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="pulsarOperacion"
            android:tag="suma"
            android:text="+"
            android:textSize="30sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/button2"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="2"
            android:textSize="30sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/button3"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="3"
            android:textSize="30sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/potencia"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="potencia"
            android:text="x²"
            android:textSize="30sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/raizcuadrada"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="operadorPulsado"
            android:text="√"
            android:textSize="30sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/buttonSeno"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="operadorPulsado"
            android:text="sin"
            android:textSize="30sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/buttonCoseno"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_buttons"
            android:onClick="operadorPulsado"
            android:text="cos"
            android:textSize="30sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/button0"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="pulsarNumero"
            android:text="0"
            android:textSize="30sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="4" />

        <Button
            android:id="@+id/coma"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:onClick="agregarComa"
            android:tag="."
            android:text=","
            android:textSize="30sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="4" />

    </androidx.gridlayout.widget.GridLayout>
</LinearLayout>