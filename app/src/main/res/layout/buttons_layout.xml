<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:columnCount="4"
        app:rowCount="6">

        <Button
            android:id="@+id/buttonAC"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="AC"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/buttonC"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="C"
            android:textSize="24sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/buttonPorcentaje"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="%"
            android:textSize="24sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/buttonDividir"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="/"
            android:textSize="24sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="0" />

        <Button
            android:id="@+id/button7"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="7"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/buttonMultiplicar"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="X"
            android:textSize="24sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/button8"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="8"
            android:textSize="24sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/button9"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="9"
            android:textSize="24sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="1" />

        <Button
            android:id="@+id/button4"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="4"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/buttonResta"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="-"
            android:textSize="24sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/button5"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="5"
            android:textSize="24sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/button6"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="6"
            android:textSize="24sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="2" />

        <Button
            android:id="@+id/button1"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="1"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/buttonsuma"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="+"
            android:textSize="24sp"
            app:layout_column="3"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/button2"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="2"
            android:textSize="24sp"
            app:layout_column="1"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/button3"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_numberbuttons"
            android:text="3"
            android:textSize="24sp"
            app:layout_column="2"
            app:layout_columnWeight="0"
            app:layout_row="3" />

        <Button
            android:id="@+id/buttonpotencia"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="3dp"
            android:background="@drawable/stylo_borde_buttons"
            android:text="x²"
            android:textSize="24sp"
            app:layout_column="0"
            app:layout_columnWeight="0"
            app:layout_row="5" />

        <Button
            android:id="@+id/buttonraizCuadrada"
            style="@style/FontStyle"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
